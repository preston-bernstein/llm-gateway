# /etc/litellm/litellm.env — copy here, chmod 600, never commit.
# The install script generates this file with a random LITELLM_MASTER_KEY.

LITELLM_MASTER_KEY=sk-litellm-<random-hex>
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# RunPod serverless (big open-weights, mid tier). Endpoint id goes in config.yaml.
RUNPOD_API_KEY=
